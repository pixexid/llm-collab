# Runtime config (created by scripts/init.py)
/collab.config.json
/agents.json
/projects.json

# Per-agent runtime state (inbox pointers, memory, identity)
agents/*/inbox.json
agents/*/memory.md
agents/*/identity.md

# Live workspace data
/Chats/
/Tasks/active/
/Tasks/backlog/
/Tasks/done/
/State/
/Index/*.md
/Logs/
/projects/*
!/projects/amiga/
!/projects/amiga/README.md
!/projects/amiga/roles-and-routing.md
!/projects/amiga/issue-queue.json
!/projects/amiga/issue-queue.md
/examples/*

# Keep directory structure
!/Chats/.gitkeep
!/Tasks/active/.gitkeep
!/Tasks/backlog/.gitkeep
!/Tasks/done/.gitkeep
!/State/inbox/read/.gitkeep
!/State/inbox/notified/.gitkeep
!/Index/.gitkeep
!/Logs/watchers/.gitkeep
!/agents/.gitkeep
!/projects/.gitkeep
!/examples/.gitkeep

# Python
__pycache__/
*.pyc
*.pyo
.venv/
venv/

# Node (PM2)
node_modules/

# Local/sensitive files
.env
.env.*
!.env.example
!.env.sample
*.pem
*.key
*.p12
*.pfx
*.crt
*.cer
*.p8
*.asc
*credentials*.json
*secrets*.json
*token*.txt

# OS
.DS_Store
*.swp
