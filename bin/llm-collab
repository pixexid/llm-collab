#!/usr/bin/env bash
set -euo pipefail

ROOT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
BIN_DIR="$ROOT_DIR/bin"

usage() {
  cat >&2 <<'USAGE'
Usage: llm-collab <script[.py]> [args...]

Runs llm-collab Python commands with Python 3.10+ even when bare python3 resolves
to the macOS system Python.
USAGE
}

if [[ $# -lt 1 ]]; then
  usage
  exit 2
fi

script="$1"
shift

if [[ "$script" != *.py ]]; then
  script="${script}.py"
fi

if [[ "$script" == */* ]]; then
  target="$script"
else
  target="$BIN_DIR/$script"
fi

if [[ ! -f "$target" ]]; then
  echo "llm-collab: unknown command script: $script" >&2
  usage
  exit 2
fi

candidate_env="${LLM_COLLAB_PYTHON:-}"
candidates=()
if [[ -n "$candidate_env" ]]; then
  candidates+=("$candidate_env")
fi
candidates+=(
  python3.14
  python3.13
  python3.12
  python3.11
  python3.10
  /opt/homebrew/bin/python3
  /usr/local/bin/python3
  python3
)

for candidate in "${candidates[@]}"; do
  if ! command -v "$candidate" >/dev/null 2>&1; then
    continue
  fi
  if "$candidate" -c 'import sys; raise SystemExit(0 if sys.version_info >= (3, 10) else 1)' >/dev/null 2>&1; then
    exec "$candidate" "$target" "$@"
  fi
done

echo "llm-collab: Python 3.10+ is required, but no compatible interpreter was found." >&2
echo "Install Python 3.10+ or set LLM_COLLAB_PYTHON to a compatible interpreter." >&2
exit 1
