#!/bin/bash
# Auto-build axsend if needed, then exec it. Use this as the stable entry point
# from any session/agent: `bin/axsend-ensure ring --app Codex --submit ...`.
set -euo pipefail
root="$(cd "$(dirname "$0")/.." && pwd)"
bash "$root/tools/axbridge/build.sh" >/dev/null

app=""
text=""
is_ring=0
has_submit=0
args=("$@")
if [[ "${1:-}" == "ring" ]]; then
  is_ring=1
fi

for ((i = 0; i < ${#args[@]}; i++)); do
  case "${args[$i]}" in
    --app)
      if (( i + 1 < ${#args[@]} )); then app="${args[$((i + 1))]}"; fi
      ;;
    --text)
      if (( i + 1 < ${#args[@]} )); then text="${args[$((i + 1))]}"; fi
      ;;
    --submit)
      has_submit=1
      ;;
  esac
done

set +e
output_file="$(mktemp "${TMPDIR:-/tmp}/axsend-ensure.XXXXXX")"
trap 'rm -f "$output_file"' EXIT
"$root/tools/axbridge/axsend" "$@" | tee "$output_file"
status=${PIPESTATUS[0]}
set -e
if (( status != 0 )); then
  exit "$status"
fi

if (( is_ring == 1 && has_submit == 1 )) && [[ -n "$app" && -n "$text" ]]; then
  if grep -Fq "QUEUED (UNCONFIRMED):" "$output_file"; then
    exit 0
  fi
  "$root/tools/axbridge/axsend" confirm --app "$app" --text "$text"
fi
