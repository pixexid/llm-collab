{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/message.schema.json",
  "title": "MessageV1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "workspace_id", "scope", "message_id", "body_ref", "recipients"],
  "properties": {"schema_version": {"const": 1}, "workspace_id": {"$ref": "#/$defs/workspaceId"}, "scope": {"$ref": "#/$defs/scope"}, "message_id": {"type": "string", "pattern": "^msg_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "body_ref": {"type": "string", "pattern": "^body_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "recipients": {"type": "array", "minItems": 1, "uniqueItems": true, "items": {"type": "string", "pattern": "^agent_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}}, "activation_import": {"$ref": "#/$defs/activationPacket"}, "extensions": {"$ref": "#/$defs/extensions"}},
  "$defs": {"token": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"}, "workspaceId": {"type": "string", "pattern": "^ws_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "scope": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"enum": ["workspace", "project"]}, "project_id": {"$ref": "#/$defs/token"}}, "allOf": [{"if": {"properties": {"kind": {"const": "project"}}}, "then": {"required": ["project_id"]}, "else": {"not": {"required": ["project_id"]}}}]}, "activationPacket": {"description": "V2 import/provenance shape only; it is not a SessionRef, native session, lease, or writer authority.", "type": "object", "additionalProperties": false, "required": ["activation", "project", "chat", "task", "worktree", "branch", "target_agent", "to"], "properties": {"activation": {"const": true}, "project": {"$ref": "#/$defs/token"}, "chat": {"type": "string", "pattern": "^CHAT-[A-Za-z0-9_-]{3,127}$"}, "task": {"type": "string", "pattern": "^TASK-[A-Za-z0-9_-]{3,127}$"}, "worktree": {"type": "string", "pattern": "^/(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+[^/]$"}, "branch": {"type": "string", "pattern": "^codex/[A-Za-z0-9][A-Za-z0-9._/-]{0,127}$"}, "target_agent": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"}, "to": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"}}}, "extensions": {"type": "object", "maxProperties": 16, "propertyNames": {"pattern": "^x_[A-Za-z][A-Za-z0-9_-]{0,63}$"}, "additionalProperties": {"type": ["string", "number", "boolean", "null"], "maxLength": 512}}}
}
