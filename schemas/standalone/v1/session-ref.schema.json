{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/session-ref.schema.json",
  "title": "SessionRefV1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "workspace_id", "scope", "session_ref_id", "endpoint_id", "native_session_id", "evidence"],
  "properties": {"schema_version": {"const": 1}, "workspace_id": {"$ref": "#/$defs/workspaceId"}, "scope": {"$ref": "#/$defs/scope"}, "session_ref_id": {"type": "string", "pattern": "^session_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "endpoint_id": {"type": "string", "pattern": "^endpoint_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "native_session_id": {"type": "string", "pattern": "^native_[A-Za-z0-9][A-Za-z0-9._:-]{2,255}$"}, "repository_binding": {"type": "object", "additionalProperties": false, "required": ["project_id", "repo_id", "canonical_cwd"], "properties": {"project_id": {"$ref": "#/$defs/token"}, "repo_id": {"$ref": "#/$defs/token"}, "canonical_cwd": {"$ref": "#/$defs/canonicalPath"}}}, "evidence": {"$ref": "#/$defs/evidence"}, "extensions": {"$ref": "#/$defs/extensions"}},
  "$defs": {"token": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"}, "workspaceId": {"type": "string", "pattern": "^ws_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "canonicalPath": {"type": "string", "pattern": "^/(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+[^/]$"}, "scope": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"enum": ["workspace", "project"]}, "project_id": {"$ref": "#/$defs/token"}}, "allOf": [{"if": {"properties": {"kind": {"const": "project"}}}, "then": {"required": ["project_id"]}, "else": {"not": {"required": ["project_id"]}}}]}, "evidence": {"type": "object", "additionalProperties": false, "required": ["source", "quality", "adapter_revision", "correlation_id", "observed_at_utc", "integrity"], "properties": {"source": {"$ref": "#/$defs/token"}, "quality": {"enum": ["best_effort", "authoritative"]}, "adapter_revision": {"$ref": "#/$defs/token"}, "correlation_id": {"$ref": "#/$defs/token"}, "observed_at_utc": {"type": "string", "format": "date-time"}, "integrity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}}, "extensions": {"type": "object", "maxProperties": 16, "propertyNames": {"pattern": "^x_[A-Za-z][A-Za-z0-9_-]{0,63}$"}, "additionalProperties": {"type": ["string", "number", "boolean", "null"], "maxLength": 512}}}
}
