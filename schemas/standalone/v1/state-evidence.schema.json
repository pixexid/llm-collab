{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/state-evidence.schema.json",
  "title": "StateEvidenceV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workspace_id", "scope", "evidence_id", "source", "quality", "revision", "correlation_id", "observed_at_utc", "integrity"],
  "properties": {
    "schema_version": {"const": 1}, "workspace_id": {"$ref": "#/$defs/workspaceId"}, "scope": {"$ref": "#/$defs/scope"},
    "evidence_id": {"type": "string", "pattern": "^evidence_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "source": {"$ref": "#/$defs/token"}, "quality": {"enum": ["best_effort", "authoritative"]}, "revision": {"$ref": "#/$defs/token"}, "correlation_id": {"$ref": "#/$defs/token"}, "observed_at_utc": {"type": "string", "format": "date-time"}, "integrity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"},
    "state": {"enum": ["persisted", "routed", "injected", "visible", "accepted", "processing", "acknowledged", "completed", "rejected_before_acceptance", "ambiguous", "pull_pending", "deferred_busy"]},
    "legacy_manifest": {"$ref": "#/$defs/legacyManifest"}, "legacy_import": {"$ref": "#/$defs/legacyImport"}, "extensions": {"$ref": "#/$defs/extensions"}
  },
  "allOf": [{"if": {"properties": {"quality": {"const": "best_effort"}}}, "then": {"not": {"properties": {"state": {"enum": ["accepted", "completed"]}}, "required": ["state"]}}}],
  "$defs": {
    "token": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"}, "workspaceId": {"type": "string", "pattern": "^ws_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "sha256": {"type": "string", "pattern": "^[0-9a-f]{64}$"},
    "scope": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"enum": ["workspace", "project"]}, "project_id": {"$ref": "#/$defs/token"}}, "allOf": [{"if": {"properties": {"kind": {"const": "project"}}}, "then": {"required": ["project_id"]}, "else": {"not": {"required": ["project_id"]}}}]},
    "manifestEntry": {"type": "object", "additionalProperties": false, "required": ["canonical_locator", "content_hash", "evidence_form_version", "cutoff_policy_revision", "source_workspace_id", "source_project_id", "source_registry_revision", "source_boundary", "trusted_importer", "transaction_id", "provenance_id", "integrity"], "properties": {"canonical_locator": {"type": "string", "pattern": "^/(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+[^/]$"}, "content_hash": {"$ref": "#/$defs/sha256"}, "evidence_form_version": {"$ref": "#/$defs/token"}, "cutoff_policy_revision": {"$ref": "#/$defs/token"}, "source_workspace_id": {"$ref": "#/$defs/workspaceId"}, "source_project_id": {"$ref": "#/$defs/token"}, "source_registry_revision": {"$ref": "#/$defs/token"}, "source_boundary": {"type": "object", "additionalProperties": false, "required": ["kind", "identity", "immutable"], "properties": {"kind": {"enum": ["source_snapshot", "ledger_checkpoint", "content_addressed_revision", "sealed_observation"]}, "identity": {"$ref": "#/$defs/token"}, "immutable": {"const": true}}}, "trusted_importer": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"$ref": "#/$defs/token"}, "revision": {"$ref": "#/$defs/token"}}}, "transaction_id": {"$ref": "#/$defs/token"}, "provenance_id": {"$ref": "#/$defs/token"}, "integrity": {"$ref": "#/$defs/sha256"}}},
    "legacyManifest": {"type": "object", "additionalProperties": false, "required": ["manifest_id", "cutoff_policy_revision", "sealed", "entries"], "properties": {"manifest_id": {"type": "string", "pattern": "^manifest_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "cutoff_policy_revision": {"$ref": "#/$defs/token"}, "sealed": {"const": true}, "entries": {"type": "array", "minItems": 1, "items": {"$ref": "#/$defs/manifestEntry"}}}},
    "legacyImport": {"type": "object", "additionalProperties": false, "required": ["manifest_id", "entry_key", "recorded_bytes_base64", "importer", "import_transaction_id", "provenance_id", "integrity"], "properties": {"manifest_id": {"type": "string", "pattern": "^manifest_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "entry_key": {"type": "object", "additionalProperties": false, "required": ["canonical_locator", "content_hash", "evidence_form_version", "cutoff_policy_revision"], "properties": {"canonical_locator": {"type": "string", "pattern": "^/(?!/)(?!.*(?:^|/)\\.{1,2}(?:/|$)).+[^/]$"}, "content_hash": {"$ref": "#/$defs/sha256"}, "evidence_form_version": {"$ref": "#/$defs/token"}, "cutoff_policy_revision": {"$ref": "#/$defs/token"}}}, "recorded_bytes_base64": {"type": "string", "contentEncoding": "base64", "minLength": 1}, "importer": {"type": "object", "additionalProperties": false, "required": ["identity", "revision"], "properties": {"identity": {"$ref": "#/$defs/token"}, "revision": {"$ref": "#/$defs/token"}}}, "import_transaction_id": {"$ref": "#/$defs/token"}, "provenance_id": {"$ref": "#/$defs/token"}, "integrity": {"$ref": "#/$defs/sha256"}}},
    "extensions": {"type": "object", "maxProperties": 16, "propertyNames": {"pattern": "^x_[A-Za-z][A-Za-z0-9_-]{0,63}$"}, "additionalProperties": {"type": ["string", "number", "boolean", "null"], "maxLength": 512}}
  }
}
