{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/agent.schema.json",
  "title": "AgentV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workspace_id", "scope", "agent_id", "roles"],
  "properties": {
    "schema_version": {"const": 1},
    "workspace_id": {"$ref": "#/$defs/workspaceId"},
    "scope": {"$ref": "#/$defs/scope"},
    "agent_id": {"type": "string", "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029])agent_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"},
    "roles": {"type": "array", "minItems": 1, "maxItems": 32, "uniqueItems": true, "items": {"$ref": "#/$defs/token"}},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "token": {"type": "string", "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029])[A-Za-z][A-Za-z0-9._-]{0,127}$"},
    "workspaceId": {"type": "string", "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029])ws_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"},
    "scope": {
      "type": "object",
      "additionalProperties": false,
      "required": ["kind"],
      "properties": {"kind": {"enum": ["workspace", "project"]}, "project_id": {"$ref": "#/$defs/token"}},
      "allOf": [{"if": {"properties": {"kind": {"const": "project"}}, "required": ["kind"]}, "then": {"required": ["project_id"]}, "else": {"not": {"required": ["project_id"]}}}]
    },
    "extensions": {
      "description": "Bounded non-authoritative annotations. Consumers must ignore these values for routing, trust, and execution.",
      "type": "object",
      "maxProperties": 8,
      "propertyNames": {"pattern": "^x_note_[A-Za-z][A-Za-z0-9_-]{0,55}$"},
      "additionalProperties": {
        "anyOf": [
          {"type": "string", "maxLength": 512, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029\\ud800-\\udfff]).*$"},
          {"type": "integer", "minimum": -9007199254740991, "maximum": 9007199254740991},
          {"type": "boolean"},
          {"type": "null"}
        ]
      }
    }
  }
}
