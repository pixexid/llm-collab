{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/workspace.schema.json",
  "title": "WorkspaceV1",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "workspace_id", "registry_revision", "projects", "repositories", "relationships"],
  "properties": {
    "schema_version": {"const": 1},
    "workspace_id": {"$ref": "#/$defs/workspaceId"},
    "registry_revision": {"$ref": "#/$defs/token"},
    "projects": {"type": "array", "minItems": 1, "items": {"type": "object", "additionalProperties": false, "required": ["project_id"], "properties": {"project_id": {"$ref": "#/$defs/token"}, "extensions": {"$ref": "#/$defs/extensions"}}}},
    "repositories": {"type": "array", "items": {"type": "object", "additionalProperties": false, "required": ["project_id", "repo_id"], "properties": {"project_id": {"$ref": "#/$defs/token"}, "repo_id": {"$ref": "#/$defs/token"}, "extensions": {"$ref": "#/$defs/extensions"}}}},
    "relationships": {"type": "array", "items": {"$ref": "#/$defs/relationship"}},
    "extensions": {"$ref": "#/$defs/extensions"}
  },
  "$defs": {
    "token": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"},
    "workspaceId": {"type": "string", "pattern": "^ws_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"},
    "extensions": {"type": "object", "maxProperties": 16, "propertyNames": {"pattern": "^x_[A-Za-z][A-Za-z0-9_-]{0,63}$"}, "additionalProperties": {"type": ["string", "number", "boolean", "null"], "maxLength": 512}},
    "repoRef": {"type": "object", "additionalProperties": false, "required": ["project_id", "repo_id"], "properties": {"project_id": {"$ref": "#/$defs/token"}, "repo_id": {"$ref": "#/$defs/token"}}},
    "relationship": {"type": "object", "additionalProperties": false, "required": ["relationship_id", "relationship_type", "source", "target", "registry_revision", "lifecycle", "revision"], "properties": {"relationship_id": {"type": "string", "pattern": "^rel_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "relationship_type": {"const": "documentation_companion"}, "source": {"$ref": "#/$defs/repoRef"}, "target": {"$ref": "#/$defs/repoRef"}, "registry_revision": {"$ref": "#/$defs/token"}, "lifecycle": {"enum": ["active", "retired"]}, "revision": {"$ref": "#/$defs/token"}, "extensions": {"$ref": "#/$defs/extensions"}}}
  }
}
