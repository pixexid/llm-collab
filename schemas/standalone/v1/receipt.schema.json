{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/receipt.schema.json",
  "title": "ReceiptV1", "type": "object", "additionalProperties": false,
  "required": ["schema_version", "workspace_id", "scope", "receipt_id", "delivery_id", "state", "evidence"],
  "properties": {"schema_version": {"const": 1}, "workspace_id": {"$ref": "#/$defs/workspaceId"}, "scope": {"$ref": "#/$defs/scope"}, "receipt_id": {"type": "string", "pattern": "^receipt_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "delivery_id": {"type": "string", "pattern": "^delivery_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "state": {"enum": ["persisted", "routed", "injected", "visible", "accepted", "processing", "acknowledged", "completed", "rejected_before_acceptance", "ambiguous", "pull_pending", "deferred_busy"]}, "evidence": {"$ref": "#/$defs/evidence"}, "extensions": {"$ref": "#/$defs/extensions"}},
  "allOf": [{"if": {"properties": {"state": {"enum": ["accepted", "completed"]}}}, "then": {"properties": {"evidence": {"properties": {"quality": {"const": "authoritative"}}}}}}],
  "$defs": {"token": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"}, "workspaceId": {"type": "string", "pattern": "^ws_[A-Za-z0-9][A-Za-z0-9_-]{2,127}$"}, "scope": {"type": "object", "additionalProperties": false, "required": ["kind"], "properties": {"kind": {"enum": ["workspace", "project"]}, "project_id": {"$ref": "#/$defs/token"}}, "allOf": [{"if": {"properties": {"kind": {"const": "project"}}}, "then": {"required": ["project_id"]}, "else": {"not": {"required": ["project_id"]}}}]}, "evidence": {"type": "object", "additionalProperties": false, "required": ["source", "quality", "revision", "correlation_id", "observed_at_utc", "integrity"], "properties": {"source": {"$ref": "#/$defs/token"}, "quality": {"enum": ["best_effort", "authoritative"]}, "revision": {"$ref": "#/$defs/token"}, "correlation_id": {"$ref": "#/$defs/token"}, "observed_at_utc": {"type": "string", "format": "date-time"}, "integrity": {"type": "string", "pattern": "^sha256:[0-9a-f]{64}$"}}}, "extensions": {"type": "object", "maxProperties": 16, "propertyNames": {"pattern": "^x_[A-Za-z][A-Za-z0-9_-]{0,63}$"}, "additionalProperties": {"type": ["string", "number", "boolean", "null"], "maxLength": 512}}}
}
