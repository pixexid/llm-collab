{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/event-envelope.schema.json",
  "title": "EventEnvelopeV1",
  "description": "Bounded adapter input only. Runner identity, subscription revision, receive time, content hash, routing, delivery, retry, registry implementation, and execution authority are deliberately absent. Canonical envelope bytes use the same frozen UTF-8, Unicode-code-point key ordering, array-order, compact-separator, exact-Unicode-scalar, safe-integer-only JSON algorithm described by StateEvidenceV1, including normalization of integer lexical -0 to JSON integer 0 before hashing. The semantic gate recursively applies Unicode NFKC first, then acronym-to-word and ordinary camel-case splitting, then casefolding and separator collapse before enforcing the complete forbidden-authority family.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "adapter_name", "adapter_version", "event_type", "source_event_id", "source_cursor", "observed_at_utc", "subject", "coalescing_key", "observed_state", "expected_outcome", "why_not_done", "next_unlock_action", "severity", "payload"],
  "properties": {
    "schema_version": {"const": 1},
    "adapter_name": {"$ref": "#/$defs/token"},
    "adapter_version": {"$ref": "#/$defs/token"},
    "event_type": {"$ref": "#/$defs/token"},
    "source_event_id": {"$ref": "#/$defs/shortText"},
    "source_cursor": {"type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "source_time_utc": {"type": ["string", "null"], "format": "date-time"},
    "subject": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "coalescing_key": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "observed_state": {"$ref": "#/$defs/shortText"},
    "expected_outcome": {"$ref": "#/$defs/shortText"},
    "why_not_done": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "next_unlock_action": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "severity": {"enum": ["quiet", "actionable", "warning", "error"]},
    "payload": {"$ref": "#/$defs/dataObject5"}
  },
