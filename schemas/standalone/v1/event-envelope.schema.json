{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/event-envelope.schema.json",
  "title": "EventEnvelopeV1", "description": "Adapter input only. Runner identity, subscription, receive time, content hash, routing, delivery, retry, and execution authority are deliberately absent.",
  "type": "object", "additionalProperties": false,
  "required": ["schema_version", "adapter_name", "adapter_version", "event_type", "source_event_id", "source_cursor", "observed_at_utc", "source_time_utc", "subject", "coalescing_key", "observed_state", "expected_outcome", "why_not_done", "next_unlock_action", "severity", "payload"],
  "properties": {"schema_version": {"const": 1}, "adapter_name": {"$ref": "#/$defs/token"}, "adapter_version": {"$ref": "#/$defs/token"}, "event_type": {"$ref": "#/$defs/token"}, "source_event_id": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "source_cursor": {"type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "observed_at_utc": {"type": "string", "format": "date-time"}, "source_time_utc": {"type": ["string", "null"], "format": "date-time"}, "subject": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "coalescing_key": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "observed_state": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "expected_outcome": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "why_not_done": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "next_unlock_action": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^[^\\u0000-\\u001f\\u007f\\r\\n]+$"}, "severity": {"enum": ["quiet", "actionable", "warning", "error"]}, "payload": {"type": "object", "maxProperties": 32, "additionalProperties": {"type": ["string", "number", "boolean", "null", "array", "object"]}}},
  "$defs": {"token": {"type": "string", "pattern": "^[A-Za-z][A-Za-z0-9._-]{0,127}$"}}
}
