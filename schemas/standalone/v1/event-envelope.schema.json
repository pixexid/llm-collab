{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://llm-collab.dev/schemas/standalone/v1/event-envelope.schema.json",
  "title": "EventEnvelopeV1",
  "description": "Bounded adapter input only. Runner identity, subscription revision, receive time, content hash, routing, delivery, retry, registry implementation, and execution authority are deliberately absent. Canonical envelope bytes use the same frozen UTF-8, Unicode-code-point key ordering, array-order, compact-separator, exact-Unicode-scalar, safe-integer-only JSON algorithm described by StateEvidenceV1, including normalization of integer lexical -0 to JSON integer 0 before hashing. The semantic gate applies NFKC, case, camel-case, and separator normalization recursively before enforcing the complete forbidden-authority family.",
  "type": "object",
  "additionalProperties": false,
  "required": ["schema_version", "adapter_name", "adapter_version", "event_type", "source_event_id", "source_cursor", "observed_at_utc", "subject", "coalescing_key", "observed_state", "expected_outcome", "why_not_done", "next_unlock_action", "severity", "payload"],
  "properties": {
    "schema_version": {"const": 1},
    "adapter_name": {"$ref": "#/$defs/token"},
    "adapter_version": {"$ref": "#/$defs/token"},
    "event_type": {"$ref": "#/$defs/token"},
    "source_event_id": {"$ref": "#/$defs/shortText"},
    "source_cursor": {"type": "string", "minLength": 1, "maxLength": 2048, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "observed_at_utc": {"type": "string", "format": "date-time"},
    "source_time_utc": {"type": ["string", "null"], "format": "date-time"},
    "subject": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "coalescing_key": {"type": "string", "minLength": 1, "maxLength": 256, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "observed_state": {"$ref": "#/$defs/shortText"},
    "expected_outcome": {"$ref": "#/$defs/shortText"},
    "why_not_done": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "next_unlock_action": {"type": "string", "minLength": 1, "maxLength": 1024, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "severity": {"enum": ["quiet", "actionable", "warning", "error"]},
    "payload": {"$ref": "#/$defs/dataObject5"}
  },
  "$defs": {
    "token": {"type": "string", "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029])[A-Za-z][A-Za-z0-9._-]{0,127}$"},
    "shortText": {"type": "string", "minLength": 1, "maxLength": 512, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029]).+$"},
    "dataString": {"type": "string", "maxLength": 4096, "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029\\ud800-\\udfff]).*$"},
    "dataScalar": {
      "anyOf": [
        {"$ref": "#/$defs/dataString"},
        {"type": "integer", "minimum": -9007199254740991, "maximum": 9007199254740991},
        {"type": "boolean"},
        {"type": "null"}
      ]
    },
    "safePropertyName": {
      "type": "string",
      "minLength": 1,
      "maxLength": 128,
      "pattern": "^(?!.*[\\u0000-\\u001f\\u007f\\u0085\\u2028\\u2029\\ud800-\\udfff]).+$",
      "not": {
        "enum": [
          "project", "projects", "project_id", "project_home",
          "workspace", "workspaces", "workspace_id", "workspace_home", "workspace_root",
          "runtime_home", "runtime_home_id", "runtime_home_realpath",
          "native_target", "native_target_id", "native_thread", "native_thread_id", "native_session", "native_session_id",
          "session", "sessions", "session_ref", "session_ref_id",
          "chat", "chats", "chat_id", "task", "tasks", "task_id", "agent", "agents", "agent_id",
          "endpoint", "endpoints", "endpoint_id", "route", "routes", "routing", "target", "target_id", "target_agent", "recipient", "recipients",
          "handler", "handler_name", "handler_implementation", "adapter_implementation", "implementation",
          "adapter", "adapter_name", "adapter_revision", "adapter_version",
          "adapter-name", "adapter-revision", "adapter-version",
          "adapter.name", "adapter.revision", "adapter.version",
          "adapterName", "adapterRevision", "adapterVersion",
          "handler_version", "handler_revision", "handler-version", "handler-revision",
          "handler.version", "handler.revision", "handlerName", "handlerVersion", "handlerRevision",
          "AdapterImplementation", "NativeSessionID",
          "identity", "Identity", "exact_identity", "exact-identity", "exact.identity", "exactIdentity",
          "revision", "Revision", "registry_revision", "registry-revision", "registry.revision", "registryRevision",
          "capability_profile", "capability_profiles", "capability_profile_id", "capability_profile_revision",
          "capability-profile", "capability-profile-id", "capability-profile-revision",
          "capability.profile", "capability.profile.id", "capability.profile.revision",
          "capabilityProfile", "capabilityProfileId", "capabilityProfileRevision",
          "profile_id", "profile_revision", "profile-id", "profile-revision",
          "profile.id", "profile.revision", "profileId", "profileRevision",
          "command", "commands", "executable", "executables", "module", "modules", "tool", "tools",
          "url", "urls", "uri", "uris", "network", "environment", "env",
          "cwd", "path", "paths", "filesystem_root", "filesystem_roots", "file_root", "file_roots",
          "filesystem-roots",
          "lease", "leases", "fence", "fencing", "fence_token",
          "retry", "retries", "retry_policy", "reconciliation", "reconcile", "reconciliation_policy",
          "retry-policy",
          "retention", "retention_policy", "feature_flag", "feature_flags", "policy", "policies",
          "routing_policy", "delivery_policy", "lease_policy", "fencing_policy", "capability_policy", "feature_policy",
          "delivery", "deliveries", "delivery_state", "delivery.state",
          "subscription_id", "subscription_revision", "subscription-id", "subscription-revision",
          "subscription.id", "subscription.revision", "subscriptionId", "subscriptionRevision",
          "received_at_utc", "received-at-utc", "received.at.utc", "receivedAtUtc",
          "receive_time", "receive_time_utc", "receive-time", "receive-time-utc",
          "receive.time", "receive.time.utc", "receiveTime", "receiveTimeUtc",
          "content_hash", "content-hash", "content.hash", "contentHash",
          "envelope_hash", "envelope-hash", "envelope.hash", "envelopeHash"
        ]
      }
    },
    "dataObject0": {"type": "object", "maxProperties": 32, "propertyNames": {"$ref": "#/$defs/safePropertyName"}, "additionalProperties": {"$ref": "#/$defs/dataScalar"}},
    "dataArray0": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/dataScalar"}},
    "dataValue1": {"anyOf": [{"$ref": "#/$defs/dataScalar"}, {"$ref": "#/$defs/dataObject0"}, {"$ref": "#/$defs/dataArray0"}]},
    "dataObject1": {"type": "object", "maxProperties": 32, "propertyNames": {"$ref": "#/$defs/safePropertyName"}, "additionalProperties": {"$ref": "#/$defs/dataValue1"}},
    "dataArray1": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/dataValue1"}},
    "dataValue2": {"anyOf": [{"$ref": "#/$defs/dataScalar"}, {"$ref": "#/$defs/dataObject1"}, {"$ref": "#/$defs/dataArray1"}]},
    "dataObject2": {"type": "object", "maxProperties": 32, "propertyNames": {"$ref": "#/$defs/safePropertyName"}, "additionalProperties": {"$ref": "#/$defs/dataValue2"}},
    "dataArray2": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/dataValue2"}},
    "dataValue3": {"anyOf": [{"$ref": "#/$defs/dataScalar"}, {"$ref": "#/$defs/dataObject2"}, {"$ref": "#/$defs/dataArray2"}]},
    "dataObject3": {"type": "object", "maxProperties": 32, "propertyNames": {"$ref": "#/$defs/safePropertyName"}, "additionalProperties": {"$ref": "#/$defs/dataValue3"}},
    "dataArray3": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/dataValue3"}},
    "dataValue4": {"anyOf": [{"$ref": "#/$defs/dataScalar"}, {"$ref": "#/$defs/dataObject3"}, {"$ref": "#/$defs/dataArray3"}]},
    "dataObject4": {"type": "object", "maxProperties": 32, "propertyNames": {"$ref": "#/$defs/safePropertyName"}, "additionalProperties": {"$ref": "#/$defs/dataValue4"}},
    "dataArray4": {"type": "array", "maxItems": 32, "items": {"$ref": "#/$defs/dataValue4"}},
    "dataValue5": {"anyOf": [{"$ref": "#/$defs/dataScalar"}, {"$ref": "#/$defs/dataObject4"}, {"$ref": "#/$defs/dataArray4"}]},
    "dataObject5": {"type": "object", "maxProperties": 32, "propertyNames": {"$ref": "#/$defs/safePropertyName"}, "additionalProperties": {"$ref": "#/$defs/dataValue5"}}
  }
}
