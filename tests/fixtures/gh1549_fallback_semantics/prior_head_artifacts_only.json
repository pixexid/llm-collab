        "pr_open": true,
        "draft_ready": true,
        "explicit_review_request": false,
        "review_visibility_exists": true,
        "final_push_utc": "2026-07-18T12:30:00Z",
        "head_reviewable_utc": "2026-07-18T12:30:00Z"
      },
      "stale_artifacts_for_prior_head": [
        {
          "type": "codex_review_body",
          "verdict": "clean",
          "oid": "amiga-abc300",
          "utc": "2026-07-18T12:10:00Z"
        },
        {
          "type": "reaction",
          "reaction": "+1",
          "oid": "amiga-abc300",
          "utc": "2026-07-18T12:20:00Z"
        }
      ],
      "expected": {
        "prior_head_verdict_is_head_attributable_for_current_head": false,
        "prior_head_reaction_is_head_attributable_for_current_head": false,
        "clock_anchor": "later_of(final_push, head_reviewable)",
        "clock_start_utc": "2026-07-18T12:30:00Z",
        "fallback_eligible_after_utc": "2026-07-18T12:45:00Z",
        "stuck_state_remains_reported_and_escalated": true
